# =============================================================================
# .env
# Variables de entorno del proyecto internado_api
# IMPORTANTE: Este archivo NO debe subirse al repositorio (.gitignore lo excluye)
# =============================================================================

# DJANGO
# Genera una SECRET_KEY nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion-generala-nueva
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# BASE DE DATOS PostgreSQL
# Debe coincidir exactamente con los valores en docker-compose.yml
DB_NAME=innotech_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432

# REDIS
REDIS_URL=redis://localhost:6379/0

# JWT — Tiempos de expiración (según especificación ERP)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — Origen del frontend Next.js
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ZONA HORARIA (según especificación ERP)
TIME_ZONE=America/Guayaquil