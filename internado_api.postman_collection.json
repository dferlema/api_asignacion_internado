    {
      "name": "🤖 Ranking XGBoost + SHAP",
      "item": [
        {
          "name": "16 - Generar ranking (XGBoost + SHAP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('Ranking generado exitosamente', function() {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "pm.test('Tiene al menos 1 estudiante', function() {",
                  "    pm.expect(response.data.total_estudiantes).to.be.above(0);",
                  "});",
                  "pm.test('Primer estudiante tiene explicacion_shap', function() {",
                  "    var primero = response.data.ranking[0];",
                  "    pm.expect(primero.explicacion_shap).to.exist;",
                  "    pm.expect(primero.explicacion_shap.contribuciones_por_variable).to.exist;",
                  "});",
                  "// Guardar UUID del primer estudiante del ranking",
                  "if (response.data.ranking && response.data.ranking.length > 0) {",
                  "    var primero = response.data.ranking[0];",
                  "    pm.collectionVariables.set('uuid_estudiante', primero.estudiante_id);",
                  "    console.log('#1 Ranking:', primero.nombre_completo, '— Puntaje:', primero.puntaje_xgboost);",
                  "    console.log('Variable más influyente:', primero.explicacion_shap.variable_mas_influyente);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/generar/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "generar", ""]
            },
            "description": "Ejecuta XGBoost sobre los estudiantes habilitados.\nRetorna el ranking completo con explicación SHAP por estudiante.\nRegistra logs en ia.log_prediccion.\n\n**No guarda en BD** — usar endpoint Asignar para persistir."
          }
        },
        {
          "name": "17 - Asignar plazas (persistir ranking)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('Asignación exitosa', function() {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "pm.test('Tiene total_asignados', function() {",
                  "    pm.expect(response.data.total_asignados).to.be.a('number');",
                  "});",
                  "console.log('Asignados:', response.data.total_asignados);",
                  "console.log('Lista espera:', response.data.total_lista_espera);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type",   "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"periodo\": \"{{periodo}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/asignar/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "asignar", ""]
            },
            "description": "Genera el ranking, lo persiste en practicas.ranking_internado\ny asigna plazas disponibles del período.\n\nLos valores SHAP se guardan en detalle_puntaje (JSONB).\nToda la operación es transaccional."
          }
        },
        {
          "name": "18 - Consultar ranking guardado en BD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('Consulta exitosa', function() {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "console.log('Total en ranking:', response.data.total);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/consultar/?periodo={{periodo}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "consultar", ""],
              "query": [{"key": "periodo", "value": "{{periodo}}"}]
            },
            "description": "Consulta el ranking y asignaciones persistidos en\npracticas.ranking_internado y practicas.asignacion_internado.\nNo vuelve a ejecutar XGBoost."
          }
        },
        {
          "name": "19 - Explicar SHAP por cédula (respaldo legal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var response = pm.response.json();",
                  "pm.test('Explicación SHAP generada', function() {",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "pm.test('Tiene nombre_completo', function() {",
                  "    pm.expect(response.data.nombre_completo).to.exist;",
                  "});",
                  "pm.test('Tiene resumen_legal', function() {",
                  "    pm.expect(response.data.resumen_legal).to.exist;",
                  "    pm.expect(response.data.resumen_legal.texto_acta).to.exist;",
                  "});",
                  "if (response.data.resumen_legal) {",
                  "    console.log('--- ACTA LEGAL ---');",
                  "    console.log(response.data.resumen_legal.texto_acta);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/explicar/?periodo={{periodo}}&cedula={{cedula_prueba}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "explicar", ""],
              "query": [
                {"key": "periodo", "value": "{{periodo}}"},
                {"key": "cedula",  "value": "{{cedula_prueba}}", "description": "Cédula del estudiante (10 dígitos)"}
              ]
            },
            "description": "Genera la explicación SHAP completa buscando por cédula.\nIdeal para responder apelaciones: adjuntar resumen_legal.texto_acta en el acta de resolución."
          }
        },
        {
          "name": "20 - Explicar SHAP por nombre",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/explicar/?periodo={{periodo}}&nombre=David",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "explicar", ""],
              "query": [
                {"key": "periodo", "value": "{{periodo}}"},
                {"key": "nombre",  "value": "David", "description": "Nombre o apellido parcial"}
              ]
            },
            "description": "Genera la explicación SHAP buscando por nombre o apellido parcial.\nSi hay más de un resultado, retorna lista de coincidencias para ser más específico."
          }
        },
        {
          "name": "21 - Explicar SHAP por UUID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/ranking/explicar/?periodo={{periodo}}&estudiante_id={{uuid_estudiante}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ranking", "explicar", ""],
              "query": [
                {"key": "periodo",        "value": "{{periodo}}"},
                {"key": "estudiante_id",  "value": "{{uuid_estudiante}}", "description": "UUID del estudiante"}
              ]
            },
            "description": "Genera la explicación SHAP buscando por UUID.\nEl UUID se guarda automáticamente al ejecutar el endpoint 16 (Generar ranking)."
          }
        }
      ]
    },

