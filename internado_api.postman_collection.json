            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"id_institucion\": 1,\n    \"area\": \"clinica\",\n    \"nombre_plaza\": \"Plaza Clínica General\",\n    \"cupo_total\": 2,\n    \"cupo_disponible\": 2,\n    \"activa\": true\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/api/v1/plazas/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "plazas", ""]
            },
            "description": "Crea una nueva plaza en practicas.plaza_practica.\nid_institucion debe ser un ID válido de practicas.institucion_receptora."
          }
        },
        {
